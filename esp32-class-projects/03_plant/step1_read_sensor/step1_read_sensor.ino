/*
  1단계 — 토양 수분 센서 값 읽기
  ----------------------------------------------------
  목표: 센서가 흙의 촉촉함을 숫자로 알려준다. 그 숫자를 시리얼에 출력.
        + 공기 중 값과 물컵 값을 직접 재서 "마름 기준"을 정한다.

  배선: 센서 AOUT → GPIO34, VCC → 3V3, GND → GND
*/

#define SOIL_PIN 34   // ADC1 입력 전용 핀 (와이파이와 같이 써도 안전)

void setup() {
  Serial.begin(115200);
  delay(300);
  Serial.println("\n=== 토양 수분 센서 읽기 ===");
  Serial.println("센서를 공기중 → 물컵 순서로 넣어보며 값 변화를 관찰하세요.");
}

void loop() {
  int raw = analogRead(SOIL_PIN);   // 0 ~ 4095 (12비트)

  // 값에 따라 간단한 막대도 같이 그려줌 (눈으로 보기 쉽게)
  int bars = map(raw, 0, 4095, 0, 20);
  String bar = "";
  for (int i = 0; i < 20; i++) bar += (i < bars) ? '#' : '.';

  Serial.printf("수분 센서 값: %4d  [%s]\n", raw, bar.c_str());
  delay(500);
}

/*
  관찰 포인트 (정전용량식 센서 기준):
    - 공기 중(마름)  → 값이 큼  (예: 3000~4095)
    - 물 속(젖음)    → 값이 작음 (예: 1200~1600)
  내 센서의 값을 적어두자:
    공기 중 값 = _______
    물컵   값 = _______
    → 마름 기준(임계값) ≈ 두 값의 중간 = _______   (3단계에서 사용)
*/
